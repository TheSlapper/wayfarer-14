# Buttons added to the main InstrumentMenu for the playlist feature.
instruments-component-menu-playlist-button = Playlist
instruments-component-menu-playlist-tooltip =
    Open the playlist window to queue MIDI files.
    Use the previous and next buttons to skip tracks.
    The playlist repeats when the last song ends.
instruments-component-menu-prev-button = Prev
instruments-component-menu-next-button = Next

# PlaylistMenu window.
instruments-playlist-menu-title = MIDI Playlist
instruments-playlist-menu-add = Add
instruments-playlist-menu-rename = Rename
instruments-playlist-menu-remove = Remove
instruments-playlist-menu-clear = Clear
instruments-playlist-menu-play = Play
instruments-playlist-menu-save = Save
instruments-playlist-menu-save-tooltip =
    When the save dialog opens, type the full filename ending in .midplaylist
    (for example MyJazz.midplaylist). The dialog does not append the extension automatically.
instruments-playlist-menu-load = Load

# Track list entries. The "-current" variant is used for the track actively playing;
# "-default" is the fallback label when the user has not given a track a custom name.
instruments-playlist-menu-track-current = { $name } (now playing)
instruments-playlist-menu-track-default = Track { $n }

# Rename dialog.
instruments-playlist-menu-rename-title = Rename Track
instruments-playlist-menu-rename-prompt = Name